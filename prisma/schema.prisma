// prisma/schema.prisma
// Full schema — adds "Pendiente" to EstadoPrestamo for the approval flow

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ─── USUARIO ───────────────────────────────────────────────
model Usuario {
  id              Int        @id @default(autoincrement())
  email           String     @unique
  passwordHash    String
  nombre          String
  apellido        String
  genero          String?
  edad            Int?
  matricula       String?    @unique
  numEmpleado     String?    @unique
  rol             Rol
  activo          Boolean    @default(true)
  emailVerificado Boolean    @default(false)
  createdAt       DateTime   @default(now())

  prestamos       Prestamo[]
  multas          Multa[]
  reportes        Reporte[]
}

enum Rol {
  Administrador
  Bibliotecario
  Estudiante
  Maestro
  Colaborador
}

// ─── AUTOR ─────────────────────────────────────────────────
model Autor {
  id     Int          @id @default(autoincrement())
  nombre String       @unique
  libros LibroAutor[]
}

// ─── LIBRO ─────────────────────────────────────────────────
model Libro {
  id          Int          @id @default(autoincrement())
  isbn        String       @unique
  titulo      String
  subtitulo   String?
  editorial   String?
  edicion     String?
  anioPub     Int?
  numPaginas  Int?
  categoria   String?
  idioma      String?
  descripcion String?
  portadaUrl  String?
  createdAt   DateTime     @default(now())

  autores     LibroAutor[]
  copias      Copia[]
}

// ─── LIBRO_AUTOR (many to many) ────────────────────────────
model LibroAutor {
  libroId Int
  autorId Int
  libro   Libro  @relation(fields: [libroId], references: [id])
  autor   Autor  @relation(fields: [autorId], references: [id])
  @@id([libroId, autorId])
}

// ─── COPIA ─────────────────────────────────────────────────
model Copia {
  id            Int         @id @default(autoincrement())
  libroId       Int
  codigoInterno String      @unique
  pasillo       String?
  estante       String?
  estado        EstadoCopia @default(Disponible)
  createdAt     DateTime    @default(now())

  libro         Libro       @relation(fields: [libroId], references: [id])
  prestamos     Prestamo[]
}

enum EstadoCopia {
  Disponible
  Prestada
  Perdida
  Dañada
}

// ─── PRESTAMO ──────────────────────────────────────────────
model Prestamo {
  id              Int            @id @default(autoincrement())
  usuarioId       Int
  copiaId         Int
  fechaPrestamo   DateTime       @default(now())
  fechaDevolucion DateTime
  fechaRealDev    DateTime?
  estado          EstadoPrestamo @default(Pendiente)   // ← starts as Pendiente
  renovaciones    Int            @default(0)

  usuario         Usuario        @relation(fields: [usuarioId], references: [id])
  copia           Copia          @relation(fields: [copiaId], references: [id])
  multa           Multa?
}

enum EstadoPrestamo {
  Pendiente   // ← NEW: waiting for librarian approval
  Activo
  Renovado
  Devuelto
  Perdido
}

// ─── MULTA ─────────────────────────────────────────────────
model Multa {
  id           Int         @id @default(autoincrement())
  prestamoId   Int         @unique
  usuarioId    Int
  monto        Float
  motivo       String
  estado       EstadoMulta @default(Pendiente)
  fecha        DateTime    @default(now())
  refTesoreria String?
  fechaPago    DateTime?

  prestamo     Prestamo    @relation(fields: [prestamoId], references: [id])
  usuario      Usuario     @relation(fields: [usuarioId], references: [id])
}

enum EstadoMulta {
  Pendiente
  Pagada
}

// ─── REPORTE ───────────────────────────────────────────────
model Reporte {
  id            Int      @id @default(autoincrement())
  generadoPorId Int
  tipo          String
  parametros    Json?
  resultadoUrl  String?
  createdAt     DateTime @default(now())

  generadoPor   Usuario  @relation(fields: [generadoPorId], references: [id])
}

// ─── TOKEN ─────────────────────────────────────────────────
model Token {
  id        Int       @id @default(autoincrement())
  email     String
  token     String    @unique
  tipo      TipoToken
  expira    DateTime
  createdAt DateTime  @default(now())
}

enum TipoToken {
  VerificacionEmail
  ResetPassword
}
